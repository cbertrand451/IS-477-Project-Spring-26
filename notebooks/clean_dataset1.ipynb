   "source": [
    "# define folder to read files from\n",
    "data_dir = Path('../data/raw/rookie_stats_data')\n",
    "csv_files = sorted(data_dir.glob('*.csv'))\n",
    "\n",
    "rookie_stats_columns = [\n",
    "    'Season', 'Age', 'Team', 'Lg', 'Pos', 'G', 'GS', 'MP', 'FG', 'FGA',\n",
    "    'FG%', '3P', '3PA', '3P%', '2P', '2PA', '2P%', 'eFG%', 'FT', 'FTA',\n",
    "    'FT%', 'ORB', 'DRB', 'TRB', 'AST', 'STL', 'BLK', 'TOV', 'PF', 'PTS',\n",
    "    'Awards'\n",
    "]\n",
    "\n",
    "file_data = {}\n",
    "\n",
    "# read each CSV file and collect column information\n",
    "for csv_file in csv_files:\n",
    "    try:\n",
    "        df = pd.read_csv(csv_file)\n",
    "        file_data[csv_file] = df\n",
    "    except EmptyDataError:\n",
    "        file_data[csv_file] = None\n",
    "\n",
    "# unify columns across all files\n",
    "if not csv_files:\n",
    "    print('No column information was found in the CSV files.')\n",
    "else:\n",
    "    updated_files = []\n",
    "    empty_files = []\n",
    "\n",
    "    # fill missing columns with NaN and save updated files\n",
    "    for csv_file, df in file_data.items():\n",
    "        if df is None:\n",
    "            fixed_df = pd.DataFrame([{column: pd.NA for column in rookie_stats_columns}])\n",
    "            empty_files.append(csv_file.name)\n",
    "            missing_columns = rookie_stats_columns.copy()\n",
    "            extra_columns = []\n",
    "        else:\n",
    "            missing_columns = [column for column in rookie_stats_columns if column not in df.columns]\n",
    "            extra_columns = [column for column in df.columns if column not in rookie_stats_columns]\n",
    "            fixed_df = df.copy()\n",
    "\n",
    "            for column in missing_columns:\n",
    "                fixed_df[column] = pd.NA\n",
    "\n",
    "            did_not_play_mask = fixed_df.drop(columns=['Season'], errors='ignore').apply(\n",
    "                lambda row: (not row.dropna().empty)\n",
    "                and row.dropna().astype(str).str.startswith('Did not play').all(),\n",
    "                axis=1,\n",
    "            )\n",
    "            columns_to_null = [column for column in fixed_df.columns if column != 'Season']\n",
    "            fixed_df.loc[did_not_play_mask, columns_to_null] = pd.NA\n",
    "\n",
    "            fixed_df = fixed_df[rookie_stats_columns]\n",
    "\n",
    "        fixed_df.to_csv(csv_file, index=False)\n",
    "\n",
    "        if missing_columns or extra_columns:\n",
    "            updated_files.append((csv_file.name, missing_columns, extra_columns))\n",
    "\n",
    "    print(f'Checked {len(csv_files)} files.')\n",
    "    print(f'Unified column set has {len(rookie_stats_columns)} columns.\\n')\n",
    "    \n",
    "\n",
    "    # report results\n",
    "    if empty_files:\n",
    "        print('Empty files filled with NaN values:\\n')\n",
    "        for file_name in empty_files:\n",
    "            print(f'  {file_name}')\n",
    "        \n",
    "\n",
    "    if updated_files:\n",
    "        print('Files updated with missing or extra columns:\\n')\n",
    "        for file_name, missing_columns, extra_columns in updated_files:\n",
    "            print(f'  {file_name}: added {missing_columns}; removed {extra_columns}')\n",
    "    else:\n",
    "        print('All files already had the same columns.')\n"
   ]
  },
